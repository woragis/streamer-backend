PORT=8080
DATABASE_URL=postgres://streamer:streamer@localhost:5432/streamer?sslmode=disable
STATE_API_TOKEN=dev-token
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REDIS_URL=redis://localhost:6379/0
INSTANCE_ID=state-api-dev
INGEST_MODE=sync
# API should not run the ingest consumer when using cmd/worker
CONSUMER_ENABLED=false

# Restream — URLs shown in /control and relay source for FFmpeg hook
RESTREAM_PUBLIC_URL=rtmp://127.0.0.1:1935
RESTREAM_RELAY_SOURCE=rtmp://127.0.0.1:1935
# Defaults to STATE_API_TOKEN if unset; must match restream container
RESTREAM_INTERNAL_TOKEN=dev-token

# Optional: default room label for worker logs (settings live in Postgres)
ROOM_ID=default

# Railway API service (streamer.api.woragis.me)
# HOST=0.0.0.0
# PORT=8080   # Railway injects PORT automatically — do not hardcode in production
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}
# CORS_ORIGINS=https://streamer.woragis.me
