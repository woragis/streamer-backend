PORT=8080
DATABASE_URL=postgres://streamer:streamer@localhost:5432/streamer?sslmode=disable
STATE_API_TOKEN=dev-token
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REDIS_URL=redis://localhost:6379/0
INSTANCE_ID=state-api-dev
INGEST_MODE=sync
# API should not run the ingest consumer when using cmd/worker
CONSUMER_ENABLED=false

# --- Phase H: platform ingest ---
ROOM_ID=default

# YouTube (worker polls live chat; auto-enabled when both are set)
GOOGLE_API_KEY=
YOUTUBE_CHANNEL_ID=
YOUTUBE_IDLE_SECONDS=30

# Kick (webhook on state-api; auto-enabled when slug is set)
KICK_CHANNEL_SLUG=
# Dev only — skip RSA signature check (e.g. Webhook.site tests)
KICK_WEBHOOK_SKIP_VERIFY=false
